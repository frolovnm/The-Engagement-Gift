---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const lastUpdated = '2026-03-13';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="TheEngagementGift" description="Get in touch with TheEngagementGift team. We'd love to hear from you!" />
	</head>
	<body>
		<Header />
		<main>
			<div class="contact-container">
				<div class="contact-header">
					<h1>Get in Touch</h1>
					<p>Have a question about engagement gifts or need personalized recommendations? We'd love to hear from you!</p>
				</div>

				<div class="contact-content">
					<div class="contact-form-section">
						<h2>Send us a Message</h2>
						<form class="contact-form" id="contactForm" action="https://formspree.io/f/xpqypnej" method="POST">
							<div class="form-group">
								<label for="name">Name</label>
								<input type="text" id="name" name="name" required />
							</div>

							<div class="form-group">
								<label for="email">Email</label>
								<input type="email" id="email" name="email" required />
							</div>

							<div class="form-group">
								<label for="subject">Subject</label>
								<input type="text" id="subject" name="subject" required />
							</div>

							<div class="form-group">
								<label for="message">Message</label>
								<textarea id="message" name="message" rows="5" required></textarea>
							</div>

							<button type="submit" class="submit-btn">Send Message</button>
						</form>
						<script>
							document.getElementById('contactForm').addEventListener('submit', () => {
								setTimeout(() => {
									document.getElementById('contactForm').reset();
								}, 100);
							});
						</script>
					</div>

					<div class="contact-info-section">
						<h2>Other Ways to Connect</h2>
						
						<div class="info-box">
							<h3>Email</h3>
							<p>
								<a href="mailto:hello@theengagementgift.com">hello@theengagementgift.com</a>
							</p>
						</div>

						<div class="info-box">
							<h3>Visit Our Blog</h3>
							<p>
								Check out our <a href="/blog">gift guides and articles</a> for inspiration and tips.
							</p>
						</div>

						<div class="info-box">
							<h3>Quick Response</h3>
							<p>
								We typically respond to inquiries within 24 hours. Thank you for reaching out!
							</p>
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}

	.contact-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 2rem;
	}

	.contact-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.contact-header h1 {
		font-size: clamp(2rem, 5vw, 2.5rem);
		color: rgb(var(--gray-dark));
		margin-bottom: 1rem;
	}

	.contact-header p {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.6;
	}

	.contact-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
	}

	@media (max-width: 768px) {
		.contact-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	.contact-form-section h2,
	.contact-info-section h2 {
		font-size: 1.5rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 1.5rem;
	}

	.form-group {
		margin-bottom: 1.5rem;
		display: flex;
		flex-direction: column;
	}

	.form-group label {
		font-weight: 600;
		margin-bottom: 0.5rem;
		color: rgb(var(--gray-dark));
	}

	.form-group input,
	.form-group textarea {
		padding: 0.75rem;
		border: 1px solid #d1d5db;
		border-radius: 6px;
		font-size: 1rem;
		font-family: inherit;
		transition: border-color 0.2s ease;
	}

	.form-group input:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: #667eea;
		box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
	}

	.submit-btn {
		background-color: #667eea;
		color: white;
		padding: 1rem 2rem;
		border: none;
		border-radius: 6px;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.3s ease;
		width: 100%;
	}

	.submit-btn:hover {
		background-color: #764ba2;
		transform: translateY(-2px);
		box-shadow: 0 10px 25px rgba(102, 126, 234, 0.2);
	}

	.info-box {
		background: #f9fafb;
		padding: 1.5rem;
		border-radius: 8px;
		margin-bottom: 1.5rem;
		border-left: 4px solid #667eea;
	}

	.info-box h3 {
		font-size: 1.1rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.5rem;
	}

	.info-box p {
		color: rgb(var(--gray));
		line-height: 1.6;
		margin: 0;
	}

	.info-box a {
		color: #667eea;
		text-decoration: none;
		font-weight: 600;
		transition: color 0.2s ease;
	}

	.info-box a:hover {
		color: #764ba2;
		text-decoration: underline;
	}
</style>
