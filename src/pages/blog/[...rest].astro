---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const POSTS_PER_PAGE = 12;

// Get all posts
const blog = await getCollection('blog');
const rings = await getCollection('rings');
const allPosts = [...blog, ...rings].sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Determine current page from URL params
const pageParam = Astro.params.rest;
const currentPage = pageParam ? parseInt(pageParam) : 1;

const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const posts = allPosts.slice(startIndex, endIndex);

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const prevPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < totalPages ? currentPage + 1 : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.search-container {
				margin-bottom: 2rem;
				display: flex;
				gap: 1rem;
			}
			#searchInput {
				flex: 1;
				padding: 0.75rem 1rem;
				border: 2px solid #e5e7eb;
				border-radius: 8px;
				font-size: 1rem;
				transition: border-color 0.2s ease;
			}
			#searchInput:focus {
				outline: none;
				border-color: rgb(var(--accent));
			}
			#filterSelect {
				padding: 0.75rem 1rem;
				border: 2px solid #e5e7eb;
				border-radius: 8px;
				font-size: 1rem;
				background: white;
				cursor: pointer;
				transition: border-color 0.2s ease;
			}
			#filterSelect:focus {
				outline: none;
				border-color: rgb(var(--accent));
			}
			.search-results-text {
				padding: 0.75rem 1rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.no-results {
				text-align: center;
				padding: 2rem;
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}
			.pagination {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 0.5rem;
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid #e5e7eb;
				flex-wrap: wrap;
			}
			.pagination a,
			.pagination button,
			.pagination span {
				padding: 0.5rem 1rem;
				border: 1px solid #e5e7eb;
				border-radius: 6px;
				text-decoration: none;
				color: rgb(var(--black));
				transition: 0.2s ease;
				background: white;
				cursor: pointer;
				font-size: 1rem;
				font-family: inherit;
			}
			.pagination a:hover,
			.pagination button:not(:disabled):hover {
				background-color: rgb(var(--accent));
				color: white;
				border-color: rgb(var(--accent));
			}
			.pagination .current {
				background-color: rgb(var(--accent));
				color: white;
				border-color: rgb(var(--accent));
				cursor: default;
				font-weight: bold;
			}
			.pagination button:disabled {
				opacity: 0.4;
				cursor: not-allowed;
			}
			.page-info {
				text-align: center;
				color: rgb(var(--gray));
				margin-top: 1rem;
				font-size: 0.9rem;
			}
			@media (max-width: 720px) {
				.search-container {
					flex-direction: column;
				}
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				.pagination {
					gap: 0.3rem;
				}
				.pagination a,
				.pagination button,
				.pagination span {
					padding: 0.4rem 0.7rem;
					font-size: 0.9rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="search-container">
					<input
						type="text"
						id="searchInput"
						placeholder="Search posts by title..."
						aria-label="Search blog posts"
					/>
					<select id="filterSelect" aria-label="Filter posts by category">
						<option value="">All Categories</option>
						<option value="engagement">Engagement Gift Guide</option>
						<option value="trending">Unique and Trending Gifts</option>
						<option value="rings">The Ring Lab</option>
						<option value="cultural">Cultural Engagement Gifts</option>
					</select>
				</div>
				<div id="searchResults" class="search-results-text"></div>
				<ul id="postsList">
				{
					posts.map((post) => {
						// Determine collection type and map to categories
						let collection = post.data.category || 'engagement'; // Use category if defined, default to engagement
						if (!post.data.category && 'collection' in post) {
							if (post.collection === 'rings') {
								collection = 'rings'; // The Ring Lab
						}
						// blog collection stays as 'engagement' (Engagement Gift Guide)
						}

						return (
								<li data-title={post.data.title.toLowerCase()} data-collection={collection}>
									<a href={`/blog/${post.id}/`}>
										{post.data.heroImage && (
											<Image width={720} height={360} src={post.data.heroImage} alt={post.data.alt || post.data.title} />
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
				<div id="noResults" class="no-results" style="display: none;">
					No posts found. Try a different search term.
				</div>
				<nav class="pagination">
					{prevPage ? (
						<a href={prevPage === 1 ? '/blog/' : `/blog/${prevPage}/`}>← Previous</a>
					) : (
						<button disabled>← Previous</button>
					)}
					
				{Array.from({ length: totalPages }, (_, i) => {
					const pageNum = i + 1;
					if (pageNum === currentPage) {
						return <button disabled>{pageNum}</button>;
					} else if (pageNum === 1) {
						return <a href="/blog/">{pageNum}</a>;
					} else {
						return <a href={`/blog/${pageNum}/`}>{pageNum}</a>;
					}
				})}
					
					{nextPage ? (
						<a href={`/blog/${nextPage}/`}>Next →</a>
					) : (
						<button disabled>Next →</button>
					)}
				</nav>
			</section>
		</main>
		<Footer />
		<script>
			const searchInput = document.getElementById('searchInput');
			const filterSelect = document.getElementById('filterSelect');
			const postsList = document.getElementById('postsList');
			const noResults = document.getElementById('noResults');
			const searchResults = document.getElementById('searchResults');
			const posts = Array.from(postsList.querySelectorAll('li'));
			const totalPosts = posts.length;

			// Check for filter parameter in URL
			const urlParams = new URLSearchParams(window.location.search);
			const filterParam = urlParams.get('filter');
			if (filterParam) {
				filterSelect.value = filterParam;
			}

			function filterAndSearch() {
				const searchTerm = searchInput.value.toLowerCase();
				const selectedFilter = filterSelect.value;

				if (!searchTerm && !selectedFilter) {
					posts.forEach(post => post.style.display = '');
					noResults.style.display = 'none';
					searchResults.textContent = '';
					return;
				}

				let visibleCount = 0;
				posts.forEach(post => {
					const title = post.dataset.title;
					const collection = post.dataset.collection;
					
					const matchesSearch = !searchTerm || title.includes(searchTerm);
					const matchesFilter = !selectedFilter || collection === selectedFilter;
					const matches = matchesSearch && matchesFilter;
					
					post.style.display = matches ? '' : 'none';
					if (matches) visibleCount++;
				});

				if (visibleCount === 0) {
					noResults.style.display = 'block';
					searchResults.textContent = '';
				} else {
					noResults.style.display = 'none';
					searchResults.textContent = `Found ${visibleCount} of ${totalPosts} posts`;
				}
			}

			searchInput.addEventListener('input', filterAndSearch);
			filterSelect.addEventListener('change', filterAndSearch);
			
			// Apply filter on page load if filter parameter exists
			if (filterParam) {
				filterAndSearch();
			}
		</script>
	</body>
</html>
