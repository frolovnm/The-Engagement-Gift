---
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import logo from '../assets/engagement-gift-blog-logo_new.png';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="logo-section">
			<a href="/" class="logo-link">
				<Image src={logo} alt={SITE_TITLE} class="logo" />
			</a>
		</div>
		<div class="internal-links" id="navMenu">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://nl.pinterest.com/theengagementgift/" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="pinterest-link">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.092-.105-.949-.2-2.405.042-3.441.223-.937 1.406-5.957 1.406-5.957s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.199 1.842.512 2.433.112.268.129.375.088.644-.097.517-.309 1.304-.359 1.486-.061.263-.217.318-.502.191-1.784-.838-2.902-3.477-2.902-5.598 0-3.763 2.735-7.222 7.886-7.222 4.139 0 7.342 2.953 7.342 6.901 0 4.118-2.595 7.431-6.199 7.431-1.211 0-2.348-.63-2.738-1.373 0 0-.599 2.282-.745 2.84-.265.993-.981 2.231-1.461 2.987 1.1.342 2.268.527 3.511.527 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
				</svg>
			</a>
		</div>
		<button class="menu-toggle" id="menuToggle" aria-label="Toggle navigation menu">
			<span></span>
			<span></span>
			<span></span>
		</button>
	</nav>
</header>

<script>
	const menuToggle = document.getElementById('menuToggle');
	const navMenu = document.getElementById('navMenu');

	menuToggle?.addEventListener('click', () => {
		navMenu?.classList.toggle('open');
		menuToggle?.classList.toggle('open');
	});

	// Close menu when a link is clicked
	const navLinks = navMenu?.querySelectorAll('a');
	navLinks?.forEach(link => {
		link.addEventListener('click', () => {
			navMenu?.classList.remove('open');
			menuToggle?.classList.remove('open');
		});
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: relative;
		z-index: 100;
	}

	.logo-section {
		display: flex;
		align-items: center;
	}

	.logo-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.logo-link:hover {
		opacity: 0.8;
	}

	.logo {
		height: 50px;
		width: auto;
		object-fit: contain;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		position: relative;
		gap: 1em;
	}

	.logo-section {
		flex: 0 0 auto;
	}

	.social-links {
		display: flex;
		gap: 0.5em;
		align-items: center;
		margin-left: auto;
		padding: 0 1em;
	}

	.pinterest-link {
		display: flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--black));
		transition: color 0.2s ease;
		text-decoration: none;
	}

	.pinterest-link:hover {
		color: rgb(var(--accent));
	}

	.pinterest-link svg {
		width: 24px;
		height: 24px;
	}

	.internal-links {
		display: flex;
		gap: 1em;
		justify-content: center;
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}

	.menu-toggle {
		display: none;
		flex-direction: column;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		gap: 6px;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		flex-shrink: 0;
	}

	.menu-toggle span {
		width: 28px;
		height: 3px;
		background-color: rgb(var(--black));
		transition: all 0.3s ease;
		border-radius: 2px;
		display: block;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--black);
	}

	@media (max-width: 768px) {
		nav {
			justify-content: space-between;
		}

		.internal-links {
			position: fixed;
			top: 70px;
			left: 0;
			right: 0;
			transform: none;
			flex-direction: column;
			background: white;
			padding: 0;
			gap: 0;
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.3s ease;
			box-shadow: 0 8px 16px rgba(var(--black), 10%);
			z-index: 999;
		}

		.internal-links.open {
			max-height: 300px;
		}

		.internal-links a {
			padding: 1em;
			border-bottom: 1px solid rgba(var(--black), 5%);
			display: block;
		}

		.menu-toggle {
			display: flex;
		}
</style>
